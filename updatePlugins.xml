<?xml version="1.0" encoding="UTF-8"?>
<!--
  Custom-repository manifest consumed by IntelliJ when the user adds this
  repo URL under Settings → Plugins → ⚙ → Manage Plugin Repositories.

  Binary distribution flows through GitHub Releases. When a new version ships:
    1. Bump `version` and refresh `<change-notes>` here,
    2. Update the ZIP URL to the new tag (only the version number changes),
    3. Commit + push,
    4. Create a GitHub Release matching the tag and upload the built ZIP as
       its asset (see RELEASING.md for the gh-CLI one-liner).

  The <id> must match plugin.xml's <id>.
-->
<plugins>
    <plugin
            id="tech.zacik.workflowviz"
            url="https://github.com/zacikpetr/workflow-visualizer/releases/download/v0.2.0/workflow-visualizer-0.2.0.zip"
            version="0.2.0">
        <idea-version since-build="252"/>
        <name>Workflow Visualizer</name>
        <vendor email="zacik.petr@gmail.com" url="https://github.com/zacikpetr/workflow-visualizer">Petr Žáčík</vendor>
        <description><![CDATA[
            IDE-native preview and analysis for Serverless Workflow (.sw.json): live
            PlantUML diagram, navigation, inspections, and semantic highlighting.
        ]]></description>
        <change-notes><![CDATA[
            <b>0.2.0</b>
            <ul>
              <li>Fixed: the diagram no longer stretches when the tool window's proportions differ from the diagram's.</li>
              <li>Changed: minimum supported IDE raised to 2025.2.</li>
              <li>Changed: definition names are now colored by default, matching the diagram's per-type palette.</li>
              <li>Updated bundled PlantUML, Batik and Gson.</li>
            </ul>
        ]]></change-notes>
    </plugin>
</plugins>
